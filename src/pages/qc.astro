---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Quality Control - ASS Converter">
    <div class="min-h-screen bg-gradient-to-br from-zinc-950 via-zinc-900 to-zinc-950 text-zinc-50 p-4 md:p-8">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <header class="mb-8 flex items-center justify-between">
                <div>
                    <h1 class="text-4xl font-extrabold tracking-tight uppercase">
                        Quality Control <span class="text-blue-500">Checker</span>
                    </h1>
                    <p class="text-sm text-zinc-500 font-medium mt-2">
                        Check subtitle files for quality issues before delivery
                    </p>
                </div>
                <a
                    href="/"
                    class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 rounded text-sm font-medium transition"
                >
                    ← Back to Converter
                </a>
            </header>

            <!-- QC App -->
            <div id="qc-app"></div>
        </div>
    </div>
</Layout>

<script>
    import { createRoot } from "react-dom/client"
    import { QCApp } from "../components/qc-app"

    const container = document.getElementById("qc-app")
    if (container) {
        const root = createRoot(container)
        root.render(<QCApp />)
    }
</script>
